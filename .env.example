# ===========================================================
# PAPITON Express — Environment Variable Template
# Salin file ini menjadi .env dan isi nilainya sebelum menjalankan docker-compose
# JANGAN commit file .env ke repository
# ===========================================================

# --- DATABASE CREDENTIALS ---
WAREHOUSE_DB_USER=postgres
WAREHOUSE_DB_PASSWORD=postgres
WAREHOUSE_DB_NAME=papiton_warehouse

SHIPPING_DB_USER=user
SHIPPING_DB_PASSWORD=password
SHIPPING_DB_NAME=shipping_test_db

ORDER_DB_USER=postgres
ORDER_DB_PASSWORD=admin123
ORDER_DB_NAME=papiton_order_tariff_service_db

NOTIFICATION_DB_USER=user
NOTIFICATION_DB_PASSWORD=password
NOTIFICATION_DB_NAME=notification_db

DWH_DB_USER=postgres
DWH_DB_PASSWORD=dwhpassword
DWH_DB_NAME=papiton_dwh

# --- API KEY (digunakan sebagai X-API-Key header untuk antar-service auth) ---
# Ganti dengan string acak yang kuat di production
API_KEY=changeme-secret-api-key-papiton

# --- FIREBASE CLOUD MESSAGING (FCM HTTP v1 API) ---
# FCM_PROJECT_ID: project ID Firebase kamu (lihat di Firebase Console → Project Settings)
FCM_PROJECT_ID=your-firebase-project-id

# FCM_SERVICE_ACCOUNT_JSON: isi seluruh konten file service account JSON sebagai satu baris
# Download dari Firebase Console → Project Settings → Service Accounts → Generate new private key
# Pastikan nilai ini dikelilingi tanda kutip jika mengandung karakter khusus
FCM_SERVICE_ACCOUNT_JSON=

# --- SMTP (Email Notifications) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user@example.com
SMTP_PASSWORD=your-smtp-password
